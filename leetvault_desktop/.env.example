# PostHog analytics — main-process telemetry. Loaded by Vite at build time and
# inlined into out/main/index.js. Without these vars, analytics silently no-ops.
# Get your project key from https://eu.posthog.com → Project Settings → API Keys
POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
POSTHOG_HOST=https://eu.i.posthog.com
