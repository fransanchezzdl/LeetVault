{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "types": ["node", "electron"],
    "outDir": "./out-types/node"
  },
  "include": [
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "src/shared/**/*.ts",
    "electron.vite.config.ts",
    "scripts/**/*.cjs",
    "tests/unit/**/*.ts",
    "tests/integration/**/*.ts",
    "tests/helpers/**/*.ts"
  ]
}
