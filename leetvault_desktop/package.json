{
  "name": "leetvault-desktop",
  "version": "2.1.6",
  "description": "LeetVault — local LeetCode tracker with spaced repetition (Electron + React rewrite)",
  "private": true,
  "main": "out/main/index.js",
  "homepage": "https://github.com/francisco-sanchez/leetvault",
  "author": {
    "name": "Francisco Sánchez de León Acevedo",
    "email": "unknown@leetvault.es"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node scripts/run.cjs dev",
    "build": "electron-vite build",
    "preview": "node scripts/run.cjs preview",
    "start": "node scripts/run.cjs preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "format": "prettier --write .",
    "test": "npm run rebuild:node && vitest run; code=$?; npm run rebuild:electron; exit $code",
    "test:watch": "npm run rebuild:node && vitest",
    "rebuild:node": "npm rebuild better-sqlite3 >/dev/null",
    "rebuild:electron": "node scripts/rebuild-electron.cjs",
    "postinstall": "node scripts/rebuild-electron.cjs",    
    "rebuild:sqlite": "electron-rebuild -f -w better-sqlite3",
    "package": "electron-vite build && electron-builder",
    "package:win": "electron-vite build && electron-builder --win nsis",
    "package:mac": "electron-vite build && electron-builder --mac dmg",
    "package:linux": "electron-vite build && electron-builder --linux AppImage deb",
    "seed:dev-db": "node scripts/seed-dev-db.cjs",
    "icons": "node scripts/icons.cjs"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@monaco-editor/react": "^4.7.0",
    "better-sqlite3": "^12.10.0",
    "eventsource-parser": "^3.1.0",
    "fastify": "^5.1.0",
    "monaco-editor": "^0.55.1",
    "react-resizable-panels": "^4.11.2",
    "simple-icons": "^16.23.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.4",
    "@tanstack/react-query": "^5.59.16",
    "@tanstack/react-table": "^8.20.5",
    "@tanstack/react-virtual": "^3.10.8",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.11",
    "@types/react-calendar-heatmap": "^1.6.7",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "electron": "^33.0.2",
    "electron-builder": "^25.1.7",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^2.3.0",
    "eslint": "^9.12.0",
    "eslint-plugin-react": "^7.37.1",
    "eslint-plugin-react-hooks": "^5.0.0",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "react": "^18.3.1",
    "react-calendar-heatmap": "^1.10.0",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.27.0",
    "recharts": "^2.13.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.3",
    "vite": "^5.4.9",
    "vitest": "^2.1.3",
    "zustand": "^5.0.0"
  }
}
